# ──────────────────────────────────────────────────────────
#  GitHub App (required)
# ──────────────────────────────────────────────────────────
GITHUB_APP_ID=your_app_id
GITHUB_WEBHOOK_SECRET=your_webhook_secret
PEM_FILE_PATH=/path/to/your-app.private-key.pem

# ──────────────────────────────────────────────────────────
#  OpenRouter (required)
# ──────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ──────────────────────────────────────────────────────────
#  Review Model (optional — defaults shown)
# ──────────────────────────────────────────────────────────
# The model used for code review. This is where quality matters most.
# Claude Sonnet 4 gives the best results for brutal, thorough code review.
# Cost: ~$0.02-0.05 per typical PR.
#
# Alternatives (in order of review quality):
#   anthropic/claude-sonnet-4       — Best. Thorough, brutal, accurate. (~$3/$15 per M tokens)
#   google/gemini-2.5-pro           — Very good. Cheaper. (~$1.25/$10 per M tokens)
#   google/gemini-2.5-flash         — Good. Very cheap and fast. (~$0.15/$0.60 per M tokens)
#   deepseek/deepseek-chat          — Decent. Budget option. (~$0.14/$0.28 per M tokens)
#   openrouter/free                 — Free but inconsistent quality.
REVIEW_MODEL=anthropic/claude-sonnet-4

# ──────────────────────────────────────────────────────────
#  Review Behaviour (optional — defaults shown)
# ──────────────────────────────────────────────────────────
# Max total diff size (chars) before refusing to review
MAX_DIFF_CHARS=120000

# Max single file diff size (chars)
MAX_FILE_CHARS=25000

# Max files to review per PR
MAX_FILES=30

# Use REQUEST_CHANGES (blocks merge) when critical/high issues are found
BLOCK_ON_ISSUES=true
